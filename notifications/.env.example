# Telegram credentials
# ---
# Copy this file to .env and fill in the values.
# .env is gitignored — never commit it.
#
# The easiest way to fill this in is to run `python3 setup.py` from the repo root.
# It will walk you through creating a Telegram bot and finding your chat ID.
#
# ── Getting your bot token ──────────────────────────────────────────────────
# 1. Open Telegram and search for @BotFather
# 2. Send: /newbot
# 3. Follow the prompts to name your bot (username must end in "bot")
# 4. BotFather will give you a token like: 1234567890:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdef
#
# ── Getting your chat ID ─────────────────────────────────────────────────────
# 1. Open a chat with your new bot and send it any message (e.g. "hello")
# 2. Open this URL in your browser (replace TOKEN with your actual token):
#    https://api.telegram.org/botTOKEN/getUpdates
# 3. Find "chat":{"id": in the response — that number is your chat ID
#    (may be negative, like -100123456789, or positive)

TELEGRAM_BOT_TOKEN=your-bot-token-here
TELEGRAM_CHAT_ID=your-chat-id-here
